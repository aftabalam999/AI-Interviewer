# =============================================
# AI Interview App - Backend Environment Variables
# =============================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/ai_interview_db?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_min_32_chars
JWT_REFRESH_EXPIRE=30d

# Groq AI (Free LLM API - https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Required for RAG (Converting Resumes & JDs to Vector Embeddings)
OPENAI_API_KEY=your_actual_openai_api_key_here

# Cloudinary (Resume/File Storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Frontend URL (CORS)
CLIENT_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Adzuna Job Search API ──────────────────────────────────────────
# Register at: https://developer.adzuna.com/
ADZUNA_APP_ID=f039d44e
ADZUNA_APP_KEY=9ca6f7296b72e6e5cde523334ea697d7
# 2-letter country code: gb | us | in | au | ca | de | fr | nl | nz | ru | sg | za
ADZUNA_COUNTRY=gb
# Cache TTL for job search results (milliseconds). Default: 300000 (5 min)
ADZUNA_CACHE_TTL_MS=300000

# ─── Redis Cache (§2.3) ────────────────────────────────────────────────────────
# Set REDIS_ENABLED=false to use in-process fallback cache only (no Redis needed)
REDIS_ENABLED=true
# Option A: full connection URL (takes precedence over host/port)
# REDIS_URL=redis://127.0.0.1:6379
# Option B: individual settings
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password
REDIS_DB=0
# Level 1 — Search result cache TTL in seconds (default 900 = 15 min)
JOBS_CACHE_SEARCH_TTL_S=900
# Level 2 — Job detail cache TTL in seconds (default 3600 = 1 hr)
JOBS_CACHE_DETAIL_TTL_S=3600

# ─── Adzuna Client Resilience (§2.4) ──────────────────────────────────────────
# Hard timeout per HTTP attempt (ms)
ADZUNA_TIMEOUT_MS=2500
# Max retries after first failure (0 = no retry, 2 = 3 total attempts)
ADZUNA_MAX_RETRIES=2
# Base delay for exponential backoff between retries (ms)
ADZUNA_RETRY_BASE_DELAY_MS=400
# Circuit breaker: failures before opening
ADZUNA_CB_FAILURE_THRESHOLD=5
# Circuit breaker: successes in HALF_OPEN before closing
ADZUNA_CB_SUCCESS_THRESHOLD=2
# Circuit breaker: ms to stay OPEN before probing (30s)
ADZUNA_CB_OPEN_TIMEOUT_MS=30000
# §2.8 Pagination: number of Adzuna pages to prefetch per query (default 3 = ~60 raw jobs)
ADZUNA_PREFETCH_PAGES=3

# ─── §3 Performance Optimizations ──────────────────────────────────────────────
# ── Gzip Compression ────────────────────────────────────────────────────────
# Minimum response size to compress (bytes). Below this = not worth compressing.
COMPRESSION_THRESHOLD_BYTES=1024
# zlib level: 1 (fastest, less compression) to 9 (slowest, best compression)
COMPRESSION_LEVEL=6
# ── Redis Connection Pool ─────────────────────────────────────────────────
# Enable TLS for cloud Redis providers (Redis Cloud, Upstash, ElastiCache)
REDIS_TLS=false
# Connect/command timeouts (ms)
REDIS_CONNECT_TIMEOUT_MS=5000
REDIS_COMMAND_TIMEOUT_MS=3000
# ── HTTP Connection Pool (Adzuna HTTPS Agent) ────────────────────────────
# Max open sockets to api.adzuna.com (parallel connections)
ADZUNA_POOL_MAX_SOCKETS=10
# Max idle (keep-alive) sockets to hold open between requests
ADZUNA_POOL_MAX_FREE_SOCKETS=5
